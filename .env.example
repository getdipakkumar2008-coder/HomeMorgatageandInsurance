# ── OpenAI ─────────────────────────────────────────────────────────────────
# Required: Your OpenAI API key for LLM-powered explanations
OPENAI_API_KEY=sk-...your-key-here...

# Optional: Override the default model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ── LangSmith Tracing ───────────────────────────────────────────────────────
# Enable LangSmith observability (set to "true" to activate)
LANGCHAIN_TRACING_V2=false

# Your LangSmith API key (get from https://smith.langchain.com)
LANGCHAIN_API_KEY=ls__...your-key-here...

# LangSmith project name for grouping traces
LANGCHAIN_PROJECT=hmip-planner

# LangSmith endpoint (default: https://api.smith.langchain.com)
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── App Settings ────────────────────────────────────────────────────────────
# Confidence threshold below which a recommendation requires human review
LOW_CONFIDENCE_THRESHOLD=0.60
